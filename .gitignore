# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/app/generated/prisma

# Respaldos locales de BD (datos sensibles, no van al repo público)
/data/backups

# Logs locales del sync
/logs

# Scripts desactivados (daemons buggy que corrompían datos — se conservan
# en local con extensión .DESACTIVADO como referencia, no van al repo)
scripts/*.DESACTIVADO
